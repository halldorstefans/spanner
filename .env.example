# Spanner Environment Variables

# PostgreSQL
POSTGRES_DB=spanner
POSTGRES_USER=spanner
POSTGRES_PASSWORD=spanner

# Ingest Service
DATABASE_URL=postgres://spanner:spanner@localhost:5432/spanner?sslmode=disable
MQTT_BROKER=localhost:1883
API_PORT=8000
LOG_LEVEL=info

# Simulator (optional, for local testing)
# SIM_VIN=MGBGT1972001
# SIM_MODE=drive
# SIM_BROKER=localhost:1883
# SIM_VERBOSE=false

# Grafana
GF_SECURITY_ADMIN_PASSWORD=spanner
GF_USERS_ALLOW_SIGN_UP=false
